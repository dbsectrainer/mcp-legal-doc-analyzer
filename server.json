{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dbsectrainer/mcp-legal-doc-analyzer",
  "description": "Domain-specific MCP tooling for legal document workflows",
  "repository": {
    "url": "https://github.com/dbsectrainer/mcp-legal-doc-analyzer",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-legal-doc-analyzer",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
