# MCP Legal Document Analyzer — environment variables
#
# Copy this file to .env and fill in the values you need.
# All variables are optional. When neither MCP_API_KEY nor MCP_JWT_SECRET
# is set the HTTP server operates without authentication (suitable for
# local / trusted-network use only).

# ------------------------------------------------------------------
# Authentication (HTTP mode only — stdio mode ignores these)
# ------------------------------------------------------------------

# Static API key. Clients must supply this value in the X-API-Key header.
# Leave unset to disable API-key authentication.
MCP_API_KEY=your-api-key-here

# Secret used to verify HMAC-SHA256 JWTs supplied as Bearer tokens in
# the Authorization header. Leave unset to disable JWT authentication.
MCP_JWT_SECRET=your-jwt-secret-here
